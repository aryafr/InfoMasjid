rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /masjids/{masjidId}/{allPaths=**} {
      allow read: if true;
      // Allow write if authenticated, uploading to their own masjidId folder, and file size < 5MB
      allow write: if request.auth != null 
                   && firestore.get(/databases/(default)/documents/masjids/$(masjidId)).data.ownerUid == request.auth.uid
                   && request.resource.size < 5 * 1024 * 1024;
    }
  }
}
