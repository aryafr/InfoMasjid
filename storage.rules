rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Tampilan TV bisa memuat semua gambar poster/QRIS yang diupload
    // Hanya Admin (login) yang bisa upload/hapus gambar
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
