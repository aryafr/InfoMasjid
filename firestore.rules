rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Tampilan TV (Frontend) bisa membaca semua data secara publik
    // Tapi hanya Admin (yang sudah login) yang bisa menambah/mengubah/menghapus
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
